{
  "name": "sticktomusic-app",
  "version": "1.7.17",
  "description": "The Content Engine for Music Artists",
  "author": "StickToMusic <zadebatal@gmail.com>",
  "private": true,
  "homepage": "/",
  "proxy": "http://localhost:3001",
  "dependencies": {
    "@breezystack/lamejs": "^1.2.7",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "@sentry/react": "^10.42.0",
    "@subframe/core": "^1.154.0",
    "clarity-js": "^0.8.59",
    "classnames": "^2.5.1",
    "cmdk": "^1.1.1",
    "copy-to-clipboard": "^3.3.3",
    "electron-store": "^10.1.0",
    "electron-updater": "^6.8.3",
    "express": "^4.22.1",
    "firebase": "^12.8.0",
    "firebase-admin": "^13.6.1",
    "framer-motion": "^12.35.0",
    "heic-to": "^1.4.2",
    "http-proxy-middleware": "^3.0.5",
    "onnxruntime-node": "^1.24.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-easy-crop": "^5.5.6",
    "react-router-dom": "^7.13.0",
    "react-scripts": "5.0.1",
    "react-window": "^2.2.7",
    "sonner": "^2.0.7",
    "utif2": "^4.1.0",
    "web-audio-beat-detector": "^8.2.34",
    "zustand": "^5.0.11"
  },
  "scripts": {
    "start": "TSC_COMPILE_ON_ERROR=true react-scripts start",
    "build": "GENERATE_SOURCEMAP=false TSC_COMPILE_ON_ERROR=true CI=false react-scripts build",
    "electron-dev": "node electron/start.js",
    "electron-build": "npm run build && electron-builder --mac",
    "electron-publish": "npm run build && electron-builder --mac --publish always",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{js,jsx}": [
      "prettier --write"
    ],
    "src/**/*.{css,json,md}": [
      "prettier --write"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "firebase-tools": "^15.5.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.19",
    "vercel": "^50.10.0"
  },
  "build": {
    "appId": "com.sticktomusic.app",
    "productName": "StickToMusic",
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.music",
      "icon": "public/icon.icns"
    },
    "extends": null,
    "electronVersion": "33.4.11",
    "asar": false,
    "afterPack": "electron/afterPack.js",
    "directories": {
      "buildResources": "public",
      "output": "dist"
    },
    "files": [
      "build/**/*",
      "electron/**/*",
      "!electron/node_modules",
      "node_modules/**/*",
      "!node_modules/.cache",
      "!node_modules/@playwright",
      "!node_modules/playwright*",
      "!node_modules/@ffmpeg",
      "!node_modules/source-map-explorer",
      "!node_modules/firebase-tools",
      "!node_modules/typescript",
      "!node_modules/@babel",
      "!node_modules/@jest",
      "!node_modules/jest*",
      "!node_modules/eslint*",
      "!node_modules/@eslint*",
      "!node_modules/webpack*",
      "!node_modules/react-scripts",
      "!node_modules/@pmmmwh",
      "!node_modules/prettier",
      "!node_modules/tailwindcss",
      "!node_modules/postcss*",
      "!node_modules/autoprefixer"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "publish": {
      "provider": "github",
      "owner": "zadebatal",
      "repo": "sticktomusic-app"
    }
  }
}
