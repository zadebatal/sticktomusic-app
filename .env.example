# StickToMusic Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git!

# ===========================================
# FIREBASE (Client-side - REACT_APP_ prefix)
# ===========================================
# Get these from Firebase Console > Project Settings > General > Your apps
REACT_APP_FIREBASE_API_KEY=your_api_key_here
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-id
REACT_APP_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=123456789
REACT_APP_FIREBASE_APP_ID=1:123456789:web:abc123

# ===========================================
# STRIPE (Client-side)
# ===========================================
# Get from Stripe Dashboard > Developers > API keys
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_live_xxxx

# ===========================================
# APP CONFIG
# ===========================================
# Comma-separated list of conductor (super admin) emails
REACT_APP_CONDUCTOR_EMAILS=your-email@example.com

# Comma-separated list of operator emails (managers who can access assigned artists)
REACT_APP_OPERATOR_EMAILS=operator@example.com

# Sentry DSN for error monitoring (optional, get from sentry.io)
REACT_APP_SENTRY_DSN=

# ===========================================
# SERVER-SIDE ONLY (Set in Vercel, NOT here)
# ===========================================
# These variables should ONLY be set in Vercel Dashboard > Settings > Environment Variables
# They contain sensitive credentials and must never be in client-side code or .env.local

# FIREBASE ADMIN (for API routes)
# Get from Firebase Console > Project Settings > Service accounts > Generate new private key
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# STRIPE (for webhooks)
# STRIPE_SECRET_KEY=sk_live_xxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxx

# LATE.CO API
# Get from Late.co dashboard
# LATE_API_KEY=sk_xxxx
